DATA_DIR=C:/Docker/postgresql

# =============================================================================
# .env – PostgreSQL HA Cluster environment variables
# =============================================================================

# Cluster identity
CLUSTER_NAME=pg-prd-cluster

# ETCD
ETCD_CLUSTER_TOKEN=pg-etcd-token-CHANGE_ME_RANDOM_32CHARS

# PostgreSQL credentials  ← CHANGE ALL IN PRODUCTION
PG_SUPERUSER_USER=postgres
PG_SUPERUSER_PASSWORD=CHANGE_ME_STRONG_SUPERUSER_PASSWORD
PG_REPLICATION_USER=replicator
PG_REPLICATION_PASSWORD=CHANGE_ME_STRONG_REPLICATION_PASSWORD
PG_REWIND_PASSWORD=CHANGE_ME_STRONG_REWIND_PASSWORD

# pgcrypto – extra databases (space-separated), leave blank for postgres only
PGCRYPTO_DATABASES=

# Late replica delay in seconds (86400 = 24 hours)
LATE_REPLICA_DELAY=86400

# Grafana
GRAFANA_ADMIN=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
